        &nbsp;&nbsp;<span class="attr">src</span>=<span class="val">"https://telling.bonfire.cafe/embed"</span><br/>
        &nbsp;&nbsp;<span class="attr">data-page</span>=<span class="val">"{% raw %}{{ page.url }}{% endraw %}"</span><br/>
        &nbsp;&nbsp;<span class="attr">title</span>=<span class="val">"Bonfire Telling Comments"</span><br/>
        &nbsp;&nbsp;<span class="attr">style</span>=<span class="val">"width:100%; border:none; min-height:400px;"</span><br/>
        <span class="tag">&gt;&lt;/iframe&gt;</span>
